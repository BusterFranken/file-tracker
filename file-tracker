#!/usr/bin/env python3
"""file-tracker: See which Claude Code plans can be executed together.

Reads plans created since the last git commit in their project, then groups
the ones that touch no common files, so you can run a whole group in parallel.
Plans that overlap with every other plan are dropped from the overview.

Usage:
  file-tracker        Show plans and which can run together
  file-tracker help   Show this help
"""

import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from collections import defaultdict
from pathlib import Path

PLANS_DIR = Path.home() / ".claude" / "plans"

BOLD = "\033[1m"
DIM = "\033[2m"
RED = "\033[31m"
GREEN = "\033[32m"
MAGENTA = "\033[35m"
RESET = "\033[0m"

FILE_EXTENSIONS = {
    "swift", "ts", "tsx", "js", "jsx", "py", "go", "rs", "java", "kt",
    "json", "yaml", "yml", "toml", "css", "html", "rb", "vue", "svelte",
    "h", "m", "c", "cpp", "cc", "hpp", "xml", "plist", "sh", "zsh",
    "graphql", "proto", "sql", "tf", "dockerfile",
}


# ── Git helpers ──────────────────────────────────────────────


def discover_git_repos():
    """Find git repos by scanning home directory (2 levels deep)."""
    candidates = set()
    home = Path.home()
    for d in home.iterdir():
        try:
            if d.name.startswith(".") or not d.is_dir():
                continue
            if (d / ".git").exists():
                candidates.add(str(d))
            else:
                for dd in d.iterdir():
                    if dd.is_dir() and (dd / ".git").exists():
                        candidates.add(str(dd))
        except PermissionError:
            continue

    repos = []
    for path in candidates:
        try:
            result = subprocess.run(
                ["git", "-C", path, "rev-parse", "--show-toplevel"],
                capture_output=True, text=True, timeout=5,
            )
            if result.returncode == 0:
                root = result.stdout.strip()
                if root not in repos:
                    repos.append(root)
        except Exception:
            continue
    return repos


def get_last_commit_time(repo):
    try:
        result = subprocess.run(
            ["git", "-C", repo, "log", "-1", "--format=%cI"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode == 0 and result.stdout.strip():
            return datetime.fromisoformat(result.stdout.strip())
    except Exception:
        pass
    return None


def find_repo_for_files(files, repos):
    for repo in repos:
        for fp in files:
            if "/" in fp:
                if os.path.exists(os.path.join(repo, fp)):
                    return repo
    for repo in repos:
        for fp in files:
            if "/" not in fp:
                try:
                    result = subprocess.run(
                        ["find", repo, "-name", fp, "-maxdepth", 5, "-print", "-quit"],
                        capture_output=True, text=True, timeout=3,
                    )
                    if result.stdout.strip():
                        return repo
                except Exception:
                    continue
    return None


# ── Time helpers ─────────────────────────────────────────────


def time_ago_dt(dt):
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    delta = datetime.now(timezone.utc) - dt
    secs = int(delta.total_seconds())
    if secs < 0:
        return "just now"
    if secs < 60:
        return f"{secs}s ago"
    elif secs < 3600:
        return f"{secs // 60}m ago"
    elif secs < 86400:
        return f"{secs // 3600}h ago"
    else:
        return f"{secs // 86400}d ago"


# ── Plan parsing ─────────────────────────────────────────────


def is_file_path(text):
    if "." not in text:
        return False
    ext = text.rsplit(".", 1)[-1].lower().rstrip(",;:)")
    if ext not in FILE_EXTENSIONS:
        return False
    code_markers = ["==", "!=", "&&", "||", "()", "{}", " = ", "->", "??", "//", "<<", ">>"]
    if any(op in text for op in code_markers):
        return False
    if " " in text:
        return False
    basename = text.rsplit("/", 1)[-1]
    name_part = basename.rsplit(".", 1)[0]
    if len(name_part) < 2:
        return False
    return True


def extract_files_from_plan(content):
    raw_files = set()
    in_code_block = False
    for line in content.split("\n"):
        stripped = line.strip()
        if stripped.startswith("```"):
            in_code_block = not in_code_block
            continue
        if in_code_block:
            continue
        for match in re.finditer(r"`([^`]+)`", line):
            text = match.group(1)
            if is_file_path(text):
                raw_files.add(text)
    by_basename = defaultdict(list)
    for fp in raw_files:
        bn = normalize_filename(fp)
        by_basename[bn].append(fp)
    files = set()
    for bn, paths in by_basename.items():
        files.add(max(paths, key=len))
    return files


def normalize_filename(path):
    return path.rsplit("/", 1)[-1]


# ── Data loading ─────────────────────────────────────────────


def get_plans():
    if not PLANS_DIR.exists():
        return {}, None

    repos = discover_git_repos()

    repo_commit_times = {}
    for repo in repos:
        t = get_last_commit_time(repo)
        if t:
            repo_commit_times[repo] = t

    plans = {}
    cutoff_used = None

    all_plan_files = sorted(
        PLANS_DIR.glob("*.md"), key=lambda p: p.stat().st_mtime, reverse=True
    )

    for f in all_plan_files:
        mtime = datetime.fromtimestamp(f.stat().st_mtime, tz=timezone.utc)
        content = f.read_text(errors="replace")
        files = extract_files_from_plan(content)
        if not files:
            continue

        repo = find_repo_for_files(files, repos)
        cutoff = repo_commit_times.get(repo) if repo else None

        if cutoff:
            if cutoff.tzinfo is None:
                cutoff = cutoff.replace(tzinfo=timezone.utc)
            if mtime <= cutoff:
                continue
            cutoff_used = cutoff
        elif repo is None:
            now = datetime.now(timezone.utc)
            if (now - mtime).total_seconds() > 86400:
                continue

        title = f.stem
        for line in content.split("\n"):
            if line.startswith("# "):
                title = line[2:].strip()
                break

        plans[f.stem] = {
            "title": title,
            "files": files,
            "mtime": mtime,
        }

    return plans, cutoff_used


# ── Display ──────────────────────────────────────────────────


def label_for(i):
    """Stable plan labels: A, B, ..., Z, AA, AB, ... (handles >26 plans)."""
    s = ""
    i += 1
    while i > 0:
        i, r = divmod(i - 1, 26)
        s = chr(65 + r) + s
    return s


def show_plans(plans, cutoff):
    if not plans:
        if cutoff:
            print(f"  {DIM}No plans since last commit ({time_ago_dt(cutoff)}).{RESET}")
        else:
            print(f"  {DIM}No plans with file references found.{RESET}")
        return

    for i, (name, data) in enumerate(plans.items()):
        label = label_for(i)
        age = time_ago_dt(data["mtime"])
        title = data["title"]
        n = len(data["files"])
        print(f"\n  {MAGENTA}[{label}]{RESET} {BOLD}{title}{RESET}  {DIM}({age}, {n} file{'s' if n != 1 else ''}){RESET}")
        for fp in sorted(data["files"]):
            print(f"      {fp}")


def find_compatible_groups(plans):
    """Maximal groups of plans that can all run together, + plans that can't.

    Two plans are compatible when they touch no common file (by basename). A
    group is a set of plans that are *pairwise* compatible, so {A,B}, {B,C} and
    {A,C} collapse into a single {A,B,C} when all three are mutually compatible.
    Returns (groups, solo, titles): groups is a list of sorted label-lists
    (largest first); solo lists plans compatible with no other (they must run
    alone); titles maps each label to its plan title.
    """
    labels = [label_for(i) for i in range(len(plans))]
    basenames, titles = {}, {}
    for label, (name, data) in zip(labels, plans.items()):
        basenames[label] = {normalize_filename(fp) for fp in data["files"]}
        titles[label] = data["title"]

    # Compatibility graph: an edge means the two plans share no file.
    neighbors = {l: set() for l in labels}
    for i, l1 in enumerate(labels):
        for l2 in labels[i + 1:]:
            if not (basenames[l1] & basenames[l2]):
                neighbors[l1].add(l2)
                neighbors[l2].add(l1)

    # Bron–Kerbosch with pivoting: enumerate maximal cliques (groups where
    # every member is compatible with every other member).
    cliques = []

    def expand(r, p, x):
        if not p and not x:
            cliques.append(r)
            return
        pivot = max(p | x, key=lambda v: len(neighbors[v] & p))
        for v in list(p - neighbors[pivot]):
            expand(r | {v}, p & neighbors[v], x & neighbors[v])
            p = p - {v}
            x = x | {v}

    expand(set(), set(labels), set())

    groups = sorted(
        (sorted(c) for c in cliques if len(c) >= 2),
        key=lambda g: (-len(g), g),
    )
    solo = sorted(next(iter(c)) for c in cliques if len(c) == 1)
    return groups, solo, titles


def show_compatible_groups(plans):
    if len(plans) == 0:
        print(f"\n  {DIM}No plans to compare.{RESET}\n")
        return
    if len(plans) == 1:
        print(f"\n  {DIM}Only one plan — nothing to batch.{RESET}\n")
        return

    groups, solo, titles = find_compatible_groups(plans)

    if groups:
        for g in groups:
            labels_str = " ".join(f"{MAGENTA}[{l}]{RESET}" for l in g)
            titles_str = f"{DIM} · {RESET}".join(f"{DIM}{titles[l]}{RESET}" for l in g)
            print(f"\n  {GREEN}●{RESET} {labels_str}  {DIM}({len(g)} plans){RESET}")
            print(f"      {titles_str}")
    else:
        print(f"\n  {DIM}No plans can run together — every pair shares a file.{RESET}")

    if solo:
        solo_str = ", ".join(f"[{l}]" for l in solo)
        print(f"\n  {DIM}Dropped — must run alone (share files with all others): {solo_str}{RESET}")

    print()


# ── Main ─────────────────────────────────────────────────────


def main():
    args = sys.argv[1:]
    cmd = args[0] if args else "show"

    if cmd in ("show", "list", "ls"):
        plans, cutoff = get_plans()

        print(f"\n{BOLD}FILE TRACKER{RESET}")
        print("=" * 42)

        cutoff_str = f" since last commit ({time_ago_dt(cutoff)})" if cutoff else ""
        print(f"\n{BOLD}PLANS{RESET}{DIM}{cutoff_str}{RESET}")
        show_plans(plans, cutoff)

        print(f"\n{'─' * 42}")
        print(f"\n{BOLD}CAN RUN TOGETHER{RESET}{DIM}  (grouped — no shared files){RESET}")
        show_compatible_groups(plans)

    elif cmd in ("help", "-h", "--help"):
        print(__doc__)
    else:
        print(f"Unknown command: {cmd}")
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
